@page "/relatorios"
@rendermode InteractiveServer
@using TrabalhoPOOPolimorfismo.Web.Services
@inject EstoqueState EstoqueState

<PageTitle>Relatórios</PageTitle>

<div class="page-header">
    <div>
        <h1>Relatórios de Estoque</h1>
        <p class="subtitle">Visualize o polimorfismo do domínio por meio de métricas coloridas e tabelas.</p>
    </div>
    <div class="stats-group">
        <div class="stat-card stat-primary">
            <span class="stat-value">@EstoqueState.TotalProdutos</span>
            <span class="stat-label">Total de produtos</span>
        </div>
        <div class="stat-card stat-secondary">
            <span class="stat-value">@EstoqueState.TotalBruto:C2</span>
            <span class="stat-label">Valor bruto</span>
        </div>
        <div class="stat-card stat-tertiary">
            <span class="stat-value">@EstoqueState.TotalAjustado:C2</span>
            <span class="stat-label">Valor ajustado</span>
        </div>
    </div>
</div>

<div class="content-grid reports-grid">
    <section class="report-panel">
        <div class="card card-soft">
            <div class="card-header">
                <h2>Resumo por tipo</h2>
            </div>
            <div class="card-body">
                <div class="summary-list">
                    <div class="summary-item">
                        <span>Perecível</span>
                        <strong>@EstoqueState.ContarPorTipo(ProdutoTipo.Perecivel)</strong>
                    </div>
                    <div class="summary-item">
                        <span>Eletrônico</span>
                        <strong>@EstoqueState.ContarPorTipo(ProdutoTipo.Eletronico)</strong>
                    </div>
                    <div class="summary-item">
                        <span>Limpeza</span>
                        <strong>@EstoqueState.ContarPorTipo(ProdutoTipo.Limpeza)</strong>
                    </div>
                    <div class="summary-item">
                        <span>Controlado</span>
                        <strong>@EstoqueState.ContarPorTipo(ProdutoTipo.Controlado)</strong>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="report-panel full-width">
        <div class="card card-soft">
            <div class="card-header">
                <h2>Detalhes do estoque</h2>
            </div>
            <div class="card-body card-table">
                @if (!EstoqueState.Produtos.Any())
                {
                    <div class="empty-state">
                        Não há produtos cadastrados para gerar o relatório.
                    </div>
                }
                else
                {
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Produto</th>
                                <th>Tipo</th>
                                <th>Risco</th>
                                <th>Armazenamento</th>
                                <th>Valor bruto</th>
                                <th>Valor ajustado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var produto in EstoqueState.Produtos)
                            {
                                <tr class="@EstoqueState.ObterClasseRisco(produto)">
                                    <td>@produto.Nome</td>
                                    <td>@produto.GetType().Name</td>
                                    <td>@produto.CalcularRiscoEstoque()</td>
                                    <td>@produto.ObterInstrucaoArmazenamento()</td>
                                    <td>@produto.CalcularValorTotalBruto():C2</td>
                                    <td>@produto.CalcularValorTotalAjustado():C2</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </section>
</div>
